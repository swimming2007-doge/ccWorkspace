# RideRecord 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 警告: .env 文件包含敏感信息，绝不应提交到 Git

# ===========================================
# 服务端配置
# ===========================================

# 服务器端口
SERVER_PORT=3000

# JWT 签名密钥 (生成一个随机字符串)
JWT_SECRET=your_random_jwt_secret_here

# JWT Token 有效期
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# 华为云 OBS 配置
# ===========================================

# OBS 访问密钥 (从华为云控制台获取)
OBS_ACCESS_KEY=your_huawei_obs_access_key
OBS_SECRET_KEY=your_huawei_obs_secret_key

# OBS Bucket 配置
OBS_BUCKET=your_bucket_name
OBS_REGION=cn-north-4
OBS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com

# ===========================================
# 高德地图 API 配置
# ===========================================

# 高德地图 Web 服务 Key
AMAP_API_KEY=your_amap_api_key

# 高德地图 JS API Key (Web端使用)
AMAP_JS_KEY=your_amap_js_key

# ===========================================
# 微信开放平台配置
# ===========================================

# 微信开放平台 AppID
WECHAT_APP_ID=your_wechat_app_id

# 微信开放平台 AppSecret
WECHAT_APP_SECRET=your_wechat_app_secret

# ===========================================
# Strava API 配置
# ===========================================

# Strava OAuth 客户端 ID
STRAVA_CLIENT_ID=your_strava_client_id

# Strava OAuth 客户端密钥
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Strava 回调地址
STRAVA_REDIRECT_URI=https://api.riderecord.com/v1/sync/strava/callback

# ===========================================
# 华为账号 OAuth 配置
# ===========================================

# 华为开发者联盟 AppID
HUAWEI_APP_ID=your_huawei_app_id

# 华为开发者联盟 AppSecret
HUAWEI_APP_SECRET=your_huawei_app_secret

# 华为 OAuth 回调地址
HUAWEI_REDIRECT_URI=https://api.riderecord.com/v1/auth/huawei/callback

# ===========================================
# 数据库配置
# ===========================================

# SQLite 数据库路径 (服务端)
DATABASE_PATH=./data/ride-record.db

# 数据库日志 (开发环境可开启)
DATABASE_LOGGING=false

# ===========================================
# 日志配置
# ===========================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===========================================
# 安全配置
# ===========================================

# API 请求签名密钥
API_SIGN_SECRET=your_api_sign_secret

# 请求限流 (每分钟请求数)
RATE_LIMIT_PER_MINUTE=100

# ===========================================
# 功能开关
# ===========================================

# 是否启用 Strava 同步
ENABLE_STRAVA_SYNC=true

# 是否启用微信分享
ENABLE_WECHAT_SHARE=true

# 是否启用探险导航模式
ENABLE_ADVENTURE_NAV=true

# ===========================================
# 开发环境配置
# ===========================================

# Node 环境: development, production
NODE_ENV=development

# 调试模式
DEBUG=false
