# RideRecord Server Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=file:./data/ride-record.db
DATABASE_LOGGING=false

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your_random_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# Huawei Cloud OBS Configuration
# ===========================================
OBS_ACCESS_KEY=your_huawei_obs_access_key
OBS_SECRET_KEY=your_huawei_obs_secret_key
OBS_BUCKET=your_bucket_name
OBS_REGION=cn-north-4
OBS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com

# ===========================================
# Huawei OAuth Configuration
# ===========================================
HUAWEI_APP_ID=your_huawei_app_id
HUAWEI_APP_SECRET=your_huawei_app_secret
HUAWEI_REDIRECT_URI=http://localhost:3000/v1/auth/huawei/callback

# ===========================================
# Amap (Gaode Maps) Configuration
# ===========================================
AMAP_API_KEY=your_amap_api_key
AMAP_JS_KEY=your_amap_js_key

# ===========================================
# WeChat Configuration
# ===========================================
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ===========================================
# Strava Configuration
# ===========================================
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/v1/sync/strava/callback

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info

# ===========================================
# Feature Flags
# ===========================================
ENABLE_STRAVA_SYNC=true
ENABLE_WECHAT_SHARE=true
ENABLE_ADVENTURE_NAV=true
