{
  "project": {
    "name": "RideRecord",
    "version": "0.1.0",
    "description": "智能骑行记录应用 - 动作检测自动启停，探险导航模式",
    "tech_stack": {
      "phone": {
        "language": "ArkTS",
        "framework": "ArkUI",
        "platform": "HarmonyOS NEXT",
        "storage": "SQLite (@ohos.data.relationalStore)",
        "sensors": "@ohos.sensor",
        "bluetooth": "@ohos.bluetooth",
        "map": "华为地图Kit / 高德地图SDK"
      },
      "watch": {
        "language": "ArkTS",
        "framework": "ArkUI (Watch)",
        "platform": "Watch OS",
        "sensors": "@ohos.sensor (加速度计、陀螺仪、心率、GPS)",
        "bluetooth": "@ohos.bluetooth (BLE)",
        "storage": "@ohos.data.preferences"
      },
      "server": {
        "runtime": "Node.js 20 LTS",
        "framework": "Express/Fastify",
        "database": "SQLite 3 (better-sqlite3)",
        "orm": "Prisma",
        "storage": "华为云OBS SDK",
        "auth": "JWT",
        "container": "Docker",
        "base_image": "node:20-alpine"
      },
      "web": {
        "framework": "Vue 3 + TypeScript",
        "build": "Vite",
        "state": "Pinia",
        "router": "Vue Router 4",
        "styling": "TailwindCSS",
        "charts": "ECharts 5",
        "map": "高德地图 JS API / Mapbox GL JS",
        "http": "Axios"
      }
    },
    "target_devices": [
      "华为 Mate 70 (HarmonyOS NEXT)",
      "Huawei Watch 3 Pro (Watch OS)",
      "Web Browser (Chrome, Safari, Firefox)"
    ],
    "design_doc": "docs/plans/ride-record-design.md",
    "srs_doc": "docs/plans/ride-record-srs.md",
    "ucd_doc": "docs/plans/ride-record-ucd.md"
  },
  "milestones": [
    {
      "id": "M1",
      "name": "Foundation",
      "description": "项目骨架、CI配置、核心抽象层、Docker容器化",
      "exit_criteria": [
        "所有项目目录创建完成",
        "基础配置文件就绪",
        "共享类型定义完成",
        "数据库Schema设计完成",
